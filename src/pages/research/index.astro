---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import LinkButton from "@/components/LinkButton.astro";
import IconArrowLeft from "@/assets/icons/IconArrowLeft.svg";
import { SITE } from "@/config";

const posts = await getCollection("blog");
const researchPosts = posts.filter(post => 
  post.data.tags && post.data.tags.includes("research")
);

const sortedResearch = getSortedPosts(researchPosts);
---

<Layout title={`Research | ${SITE.title}`}>
  <Header />
  <main id="main-content" class="mb-auto mx-auto w-full max-w-3xl px-4">
    <section class="mb-12">
      <h1 class="text-4xl font-bold mb-3">Research Papers</h1>
      <p class="text-lg text-foreground/80">
        A collection of my research papers and publications in AI, machine learning, and scientific discovery.
      </p>
    </section>
    
    {
      sortedResearch.length > 0 ? (
        <>
          <div class="mb-2 text-sm text-muted">
            {sortedResearch.length} paper{sortedResearch.length > 1 ? "s" : ""}
          </div>
          <ul>
            {sortedResearch.map((data) => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </>
      ) : (
        <p class="text-center text-gray-500 py-12">No research papers found.</p>
      )
    }

    <hr class="my-8 border-border" />

    <div class="my-8 text-center">
      <LinkButton href="/">
        <IconArrowLeft class="inline-block" />
        Back to Home
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>
